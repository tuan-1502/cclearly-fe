# API Configuration
# Set VITE_MOCK_API=true to use MSW mock data (offline dev)
# Set VITE_MOCK_API=false to connect to real backend
VITE_MOCK_API=false

# Backend URL - khi deploy sẽ thay đổi giá trị này
# Trong dev, vite proxy tự forward /api -> localhost:8080
# VITE_API_URL=http://localhost:8080/api

# Google OAuth2 Client ID (match with backend configuration)
VITE_GOOGLE_CLIENT_ID=373532301438-d27049mpvuho41qr5e5e8jckkqrql4l2.apps.googleusercontent.com
